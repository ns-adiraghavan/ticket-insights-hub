{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ticket-insights-hub",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client"
  },
  "observability": {
    "enabled": true
  }
}
